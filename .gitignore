# Whitelist .gitignore — default-deny. Ignore everything at the top level,
# then re-include only the paths that belong in the repo. New/untracked junk
# and the local dev `config/` are therefore never committed by accident.
/*

# Tracked directories
!/.github/
!/.devcontainer/
!/.agents/
!/custom_components/
!/docs/
!/scripts/

# Tracked top-level files
!/.gitattributes
!/.gitignore
!/CHANGELOG.md
!/LICENSE
!/README.md
!/hacs.json
!/zensical.en.toml
!/zensical.ko.toml

# AGENTS.md is the agent source of truth. CLAUDE.md / GEMINI.md are local
# symlinks to it; .gemini and .claude's per-item symlinks are local per-tool
# scaffolding into .agents. Only .claude/settings.json (Claude-specific,
# shared) is tracked; settings.local.json stays per-developer.
!/AGENTS.md
!/.claude
/.claude/*
!/.claude/settings.json

# Noise inside tracked directories
__pycache__/
*.py[cod]
.DS_Store

# .agents is the agent source of truth (skills/, workflows/, agents/, memory/).
# Per-developer local settings never belong in it.
/.agents/settings.local.json
