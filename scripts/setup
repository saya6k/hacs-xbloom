#!/usr/bin/env bash
# Wire this checkout into the devcontainer's baked-in Home Assistant install.
#
# The devcontainer base image (see .devcontainer/devcontainer.json) is the
# official homeassistant/home-assistant image, pinned to a dev-branch nightly.
# The image tag must match hacs.json's `homeassistant` floor and
# requirements_test.txt's homeassistant pin — one version string across all
# three. (Move all three to ">=2026.8.0b0" once the 2026.8 beta ships.)
#
# Unlike a generic Python devcontainer, the image already bundles HA core, the
# frontend, and every native/runtime dependency default_config needs (ffmpeg,
# go2rtc, PyTurboJPEG, aioesphomeapi, bleak, hassil, home-assistant-intents)
# — so there is nothing to apt/apk here beyond the dev-only Python tools the
# runtime image doesn't ship. homeassistant in requirements_test.txt is
# satisfied by the image's preinstalled copy.
set -euo pipefail

cd "$(dirname "$0")/.."

pip3 install --no-cache-dir -r requirements_test.txt ruff colorlog

mkdir -p config
if [ ! -f config/configuration.yaml ]; then
  cat > config/configuration.yaml <<'YAML'
# ha_xbloom devcontainer configuration.
# Identity values distinguish this dev instance from any production
# Home Assistant on the host network. Adjust latitude/longitude/timezone
# as needed for your locale; everything else is intentionally minimal.
homeassistant:
  name: ha_xbloom Dev
  latitude: 0
  longitude: 0
  elevation: 0
  unit_system: metric
  time_zone: UTC
  external_url: "http://hacs-xbloom-dev:8123"
  internal_url: "http://hacs-xbloom-dev:8123"

default_config:

http:
  server_port: 8123

logger:
  default: info
  logs:
    custom_components.xbloom: debug
    xbloom: debug
YAML
fi

# Symlink the integration into HA's config dir so edits hot-reload.
mkdir -p config/custom_components
ln -sfn "$PWD/custom_components/xbloom" config/custom_components/xbloom

echo "Setup complete. Run scripts/develop to start Home Assistant."
