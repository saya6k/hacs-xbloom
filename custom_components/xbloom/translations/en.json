  "services": {
    "execute_recipe": {
      "name": "Execute recipe",
      "description": "Run a saved XBloom recipe, optionally overriding the grind size and/or grinder RPM for this brew only (coffee grinding recipes only).",
      "fields": {
        "recipe_name": {
          "name": "Recipe name",
          "description": "Name of the saved recipe to run. Defaults to the currently selected recipe if omitted."
        },
        "grind_size": {
          "name": "Grind size",
          "description": "Override the grind size (0 = finest, 80 = coarsest) for this brew only."
        },
        "rpm": {
          "name": "Grinder RPM",
          "description": "Override the grinder RPM for this brew only."
        },
        "bypass_volume": {
          "name": "Bypass volume",
          "description": "Bypass water volume in ml added after the pours (0 = bypass off). Can be added even if the recipe has no bypass. Coffee recipes only."
        },
        "bypass_temperature": {
          "name": "Bypass temperature",
          "description": "Bypass water temperature in °C (0 = bypass off). Pair with a non-zero bypass volume. Coffee recipes only."
        }
      }
    }
