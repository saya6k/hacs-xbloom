{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git pull --ff-only 2>&1 || true",
            "statusMessage": "Pulling latest…",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "container stop hacs-xbloom-dev 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Stopping devcontainer…"
          }
        ]
      }
    ]
  }
}
